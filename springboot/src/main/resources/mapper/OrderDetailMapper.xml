<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.OrderDetailMapper">

    <select id="selectAll" resultType="com.example.entity.OrderDetail">
        select * from `order_detail`
        <where>
            <if test="orderId != null"> order_id = #{orderId}</if>
            <if test="groupOrderId != null"> group_order_id = #{groupOrderId}</if>
        </where>
        order by id desc
    </select>

    <select id="selectById" resultType="com.example.entity.OrderDetail">
        select * from `order_detail` where id = #{id}
    </select>

    <delete id="deleteById">
        delete from `orderDetail` where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.example.entity.OrderDetail">
        insert into `order_detail`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="goodsId != null">goods_id,</if>
            <if test="num != null">num,</if>
            <if test="orderId != null">order_id,</if>
            <if test="goodsImg != null">goods_img,</if>
            <if test="goodsName != null">goods_name,</if>
            <if test="goodsPrice != null">goods_price,</if>
            <if test="groupOrderId != null">group_order_id,</if>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="goodsId != null">#{goodsId},</if>
            <if test="num != null">#{num},</if>
            <if test="orderId != null">#{orderId},</if>
            <if test="goodsImg != null">#{goodsImg},</if>
            <if test="goodsName != null">#{goodsName},</if>
            <if test="goodsPrice != null">#{goodsPrice},</if>
            <if test="groupOrderId != null">#{groupOrderId},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.example.entity.OrderDetail">
        update `order_detail`
        <set>
            <if test="id != null">
                id = #{id},
            </if>
            <if test="goodsId != null">
                goods_id = #{goodsId},
            </if>
            <if test="num != null">
                num = #{num},
            </if>
            <if test="orderId != null">
                order_id = #{orderId},
            </if>
            <if test="goodsImg != null">
                goods_img = #{goodsImg},
            </if>
            <if test="goodsName != null">
                goods_name = #{goodsName},
            </if>
            <if test="goodsPrice != null">
                goods_price = #{goodsPrice},
            </if>
            <if test="groupOrderId != null">
                group_order_id = #{groupOrderId},
            </if>
        </set>
        where id = #{id}
    </update>

</mapper>